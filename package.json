{
    "name": "syncnote-frontend",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "prepare": "husky install"
    },
    "dependencies": {
        "next": "16.2.4",
        "react": "19.2.4",
        "react-dom": "19.2.4"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.2",
        "@commitlint/config-conventional": "^20.5.0",
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "^9",
        "eslint-config-next": "16.2.4",
        "eslint-config-prettier": "^10.1.8",
        "husky": "^8.0.0",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.3",
        "tailwindcss": "^4",
        "typescript": "^5"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --max-warnings=0 --fix",
            "prettier --write"
        ],
        "*.{json,md,css}": [
            "prettier --write"
        ]
    }
}
